# Production environment for Vercel.
# Add these in Vercel Project Settings -> Environment Variables.

# Server-only OpenAI configuration. Do not expose this key in client code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Server-only Replicate token. Used by image generation/edit routes.
REPLICATE_API_TOKEN=

# Must be false for production launch. true only enables clearly labeled demo placeholders.
NEXT_PUBLIC_DEMO_MODE=false

# Public production URL used for auth redirects and links.
NEXT_PUBLIC_SITE_URL=https://diamond-design-ai.vercel.app

# Browser-safe Supabase project URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Approximate cost tracking constants. Tune to your current provider pricing.
ESTIMATED_COST_REPLICATE_FLUX_2_PRO_IMAGE=0.04
ESTIMATED_COST_REPLICATE_GPT_IMAGE_2_MEDIUM_IMAGE=0.047
ESTIMATED_COST_REPLICATE_NANO_BANANA_2_1K_IMAGE=0.067
ESTIMATED_COST_REPLICATE_SEEDREAM_5_LITE_IMAGE=0.035
ESTIMATED_COST_OPENAI_CHAT=0.01
ESTIMATED_COST_OPENAI_DESIGN_BRIEF=0.02
